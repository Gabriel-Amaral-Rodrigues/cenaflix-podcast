<persistence xmlns="http://xmlns.jcp.org/xml/ns/persistence"
             version="2.1">

  <persistence-unit name="CenaflixPU" transaction-type="RESOURCE_LOCAL">
    <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>

    <class>model.Podcast</class>

    <properties>
      <property name="javax.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/cenaflix"/>
      <property name="javax.persistence.jdbc.user" value="root"/>
      <property name="javax.persistence.jdbc.password" value="9687"/>
      <property name="javax.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>

      <property name="eclipselink.ddl-generation" value="create-tables"/>
    </properties>

  </persistence-unit>
</persistence>